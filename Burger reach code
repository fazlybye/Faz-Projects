local function isTouchOn(button, position)
    local buttonPos = button.AbsolutePosition
    local buttonSize = button.AbsoluteSize
    return position.X >= buttonPos.X and position.X <= buttonPos.X + buttonSize.X
        and position.Y >= buttonPos.Y and position.Y <= buttonPos.Y + buttonSize.Y
end

UserInputService.InputBegan:Connect(function(input, processed)
    if not ScriptSettings.ShowButtons then return end
    if input.UserInputType == Enum.UserInputType.Touch then
        if isTouchOn(shootButton, input.Position) then
            shootTouchId = input
            startShootHold()
        elseif isTouchOn(passButton, input.Position) then
            passTouchId = input
            startPassHold()
        end
    elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
        if isTouchOn(shootButton, input.Position) then startShootHold()
        elseif isTouchOn(passButton, input.Position) then startPassHold() end
    end
    if not processed then
        if input.KeyCode == Enum.KeyCode.E then startShootHold()
        elseif input.KeyCode == Enum.KeyCode.Q then startPassHold() end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if not ScriptSettings.ShowButtons then return end
    if input.UserInputType == Enum.UserInputType.Touch then
        if input == shootTouchId then fireShoot()
        elseif input == passTouchId then firePass() end
    elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
        fireShoot()
        firePass()
    elseif input.KeyCode == Enum.KeyCode.E then fireShoot()
    elseif input.KeyCode == Enum.KeyCode.Q then firePass() end
end)

