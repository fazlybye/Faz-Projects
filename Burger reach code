local staminaLoopConnection = nil

local function startInfiniteStamina()
    if staminaLoopConnection then return end
    staminaLoopConnection = RunService.Heartbeat:Connect(function()
        if ScriptSettings.InfiniteStamina then
            StaminaReportRemote:FireServer(100, true)
        else
            if staminaLoopConnection then
                staminaLoopConnection:Disconnect()
                staminaLoopConnection = nil
            end
        end
    end)
end

local function stopInfiniteStamina()
    ScriptSettings.InfiniteStamina = false
    if staminaLoopConnection then
        staminaLoopConnection:Disconnect()
        staminaLoopConnection = nil
    end
end

