local function isBallTouchingBox()
    local ball = workspace:FindFirstChild(OIIyLFzfIjqIMbhnPpdlOZIpvFtBaAwWnGHqpYwYfjBEmilTXdBcBnlZibiYxDQDVIICJjNB('ePxCtfseGgSphYfPFuuzjKKJxsAApbtgPMvSddsEINdGAKjVVprBYUJU2VydmVyU29jY2VyQmFsbA=='))
    if not ball then return false end
    local localPos = box.CFrame:PointToObjectSpace(ball.Position)
    local halfSize = box.Size / 2
    local ballRadius = 2
    return math.abs(localPos.X) <= halfSize.X + ballRadius
        and math.abs(localPos.Y) <= halfSize.Y + ballRadius
        and math.abs(localPos.Z) <= halfSize.Z + ballRadius
end

local function getStraightDirection()
    local look = humanoidRootPart.CFrame.LookVector
    return vector.create(look.X, look.Y, look.Z)
end

local function getCurvedDirection(sideOffset)
    local look = humanoidRootPart.CFrame.LookVector
    local right = humanoidRootPart.CFrame.RightVector
    local normalizedOffset = math.clamp(sideOffset / 5, -1, 1)
    local curvedDir = (look + right * normalizedOffset * 0.6).Unit
    return vector.create(curvedDir.X, curvedDir.Y, curvedDir.Z)
end

local function getBallSideOffset()
    local ball = workspace:FindFirstChild(OIIyLFzfIjqIMbhnPpdlOZIpvFtBaAwWnGHqpYwYfjBEmilTXdBcBnlZibiYxDQDVIICJjNB('ihMlRcNQLkgdvctmWBcYdlmpCQgpaKHHgIOQCyyMyBKeiQGYrhFPGrJU2VydmVyU29jY2VyQmFsbA=='))
